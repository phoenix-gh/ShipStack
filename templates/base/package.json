{
  "name": "{{projectName}}",
  "description": "ShipStack app generated for TanStack Start on Cloudflare Workers.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "generate:routes": "tsr generate",
    "build": "pnpm generate:routes && vite build && tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm deploy:dry-run",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "verify:deployed": "node scripts/verify-deployed.mjs",
    "cf-typegen": "wrangler types",
    "lint": "pnpm format:check",
    "format:check": "prettier --check \"**/*.{md,json,jsonc,yml,yaml,ts,tsx,css}\"",
    "format": "prettier --write \"**/*.{md,json,jsonc,yml,yaml,ts,tsx,css}\"",
    "typecheck": "pnpm generate:routes && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-cli": "^1.167.17",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16",
    "wrangler": "^4.103.0"
  }
}
