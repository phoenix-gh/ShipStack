{
  "name": "@shipstack/cli",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "templates",
    "package.json"
  ],
  "bin": {
    "shipstack": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/make-bin-executable.mjs",
    "prepack": "pnpm build && node scripts/copy-templates.mjs",
    "postpack": "node scripts/clean-templates.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@shipstack/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "typescript": "^6.0.3"
  }
}
