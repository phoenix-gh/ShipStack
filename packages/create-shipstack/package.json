{
  "name": "create-shipstack-app",
  "version": "0.1.0-alpha.0",
  "description": "Create a new ShipStack TanStack Start app.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "package.json"
  ],
  "bin": {
    "create-shipstack-app": "./dist/cli.js",
    "create-shipstack": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/make-bin-executable.mjs",
    "prepack": "pnpm build",
    "typecheck": "pnpm --filter @shipstack/cli build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shipstack/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "typescript": "^6.0.3"
  }
}
